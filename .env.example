# VeriJoule Core UI — environment variables
#
# Copy this file to `.env.local` and fill in values for local dev:
#   cp .env.example .env.local
#
# On Vercel: Project → Settings → Environment Variables (same keys).
#
# All variables here use the NEXT_PUBLIC_ prefix, so they are embedded in the
# client bundle and visible in the browser. Do not put private server secrets here.
#
# Typed keys are also listed in `env.d.ts` for TypeScript autocomplete.

# --- Required ---

# Privy app ID (dashboard.privy.io). Required for wallet login and for production builds.
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Required when deployed (ledger + My Retirements panels) ---

# Ponder GraphQL base URL. Local dev can omit (defaults to http://localhost:42069).
# Production: your Railway (or other) HTTPS origin — POST targets this URL (/, not only /graphql).
# Example: https://verijoule-indexer-production.up.railway.app
# The indexer must allow CORS from your UI origin (e.g. Vercel).
NEXT_PUBLIC_INDEXER_URL=

# --- Recommended for production ---

# Sepolia JSON-RPC URL (Alchemy, Infura, etc.). Optional; uses a public endpoint if unset.
# Treat like a rate-limited API key — restrict by domain in your provider dashboard.
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key

# --- Optional (defaults exist in code) ---

# MapLibre style JSON URL. Default: Carto dark matter (no API key).
# NEXT_PUBLIC_MAPLIBRE_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# VeriJouleCoreREC proxy on Sepolia (see lib/contracts/config.ts).
# NEXT_PUBLIC_VERIJ_CORE_REC_ADDRESS=0x62fb26B311bfde6BcEB24D0452851E922b9e84d9

# VeriJouleCoreSettlement proxy on Sepolia (see lib/contracts/config.ts).
# NEXT_PUBLIC_VERIJ_CORE_SETTLEMENT_ADDRESS=0x77C5cb632aa28AA72202bbe842dE901Ff3711b6f

# Circle test USDC on Sepolia (see lib/contracts/usdc.ts).
# NEXT_PUBLIC_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
